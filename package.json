{
  "name": "paella-opencast",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://paellaplayer.upv.es/",
  "packageManager": "npm@11.12.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polimediaupv/paella-opencast"
  },
  "keywords": [
    "paella",
    "player",
    "opencast"
  ],
  "scripts": {
    "dev:engage": "turbo dev --filter=engage-paella-player...",
    "dev:libs": "turbo dev --filter=\"./packages/*\"",
    "build:libs": "turbo build --filter=\"./packages/*\"",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "turbo run test:e2e --filter=engage-paella-player",
    "clean:build": "turbo clean:build && rimraf .turbo coverage",
    "clean:deps": "rimraf node_modules",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status",
    "changeset:publish": "npm run build:libs && changeset publish"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "doc"
  ],
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@estruyf/github-actions-reporter": "^1.12.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "turbo": "^2.9.6",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "rimraf": "^6.1.3"
  }
}
