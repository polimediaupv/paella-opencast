{
  "name": "@asicupv/paella-opencast-plugins",
  "version": "2.0.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/polimediaupv/paella-opencast"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/types/paella-opencast-plugins.es.d.ts",
      "import": "./dist/paella-opencast-plugins.es.js",
      "require": "./dist/paella-opencast-plugins.cjs.js"
    },
    "./paella-opencast-plugins.css": {
      "import": "./dist/paella-opencast-plugins.css",
      "require": "./dist/paella-opencast-plugins.css"
    }
  },
  "files": [
    "dist/*",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc && vite build --watch --emptyOutDir=false",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "clean:build": "rimraf .turbo dist coverage",
    "clean:deps": "rimraf node_modules"
  },
  "devDependencies": {
    "@asicupv/paella-extra-plugins": "^2.9.1",
    "@asicupv/paella-opencast-core": "^2.0.3",
    "@asicupv/paella-user-tracking": "^2.4.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@asicupv/paella-extra-plugins": "^2.9.0",
    "@asicupv/paella-opencast-core": "^2.0.2",
    "@asicupv/paella-user-tracking": "^2.4.1"
  }
}
