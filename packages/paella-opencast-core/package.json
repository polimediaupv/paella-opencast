{
  "name": "@asicupv/paella-opencast-core",
  "version": "2.0.2",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/types/paella-opencast-core.es.d.ts",
      "import": "./dist/paella-opencast-core.es.js",
      "require": "./dist/paella-opencast-core.cjs.js"
    },
    "./paella-opencast-core.css": {
      "import": "./dist/paella-opencast-core.css",
      "require": "./dist/paella-opencast-core.css"
    }
  },
  "files": [
    "dist/*",
    "README.md"
  ],
  "scripts": {
    "dev": "tsc && vite build --watch --emptyOutDir=false",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "clean:build": "rimraf .turbo dist coverage",
    "clean:deps": "rimraf node_modules"
  },
  "devDependencies": {
    "@asicupv/paella-core": "^2.12.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "dependencies": {
    "@asicupv/paella-opencast-skin": "^2.0.1"
  },
  "peerDependencies": {
    "@asicupv/paella-core": "^2.11.3"
  }
}
